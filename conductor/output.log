+        }
+        with tempfile.TemporaryDirectory() as tmp_dir:
+            path = Path(tmp_dir) / "scene.json"
+
+            manifest_north = {**manifest_base, "lighting": {"global_direction": "north", "ambient_strength": 0.5}}
+            path.write_text(json.dumps(manifest_north), encoding="utf-8")
+            program_north = load_scene_program(path)
+            resolved_north = resolve_scene_layout(program_north)
+            result_north = assemble_scene(program_north, resolved_north, repo_root=Path(tmp_dir))
+
+            manifest_east = {**manifest_base, "lighting": {"global_direction": "east", "ambient_strength": 0.5}}
+            path.write_text(json.dumps(manifest_east), encoding="utf-8")
+            program_east = load_scene_program(path)
