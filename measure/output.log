import json
import shutil
from pathlib import Path
from asf.compilers import load_compiler_program, compile_program

REFERENCE_DIR = Path("reference/demo_assets")

# Families that compile via sprite compiler
sprite_families = [
    'character_sheet',
    'prop_sheet', 
    'fx_sheet',
    'tileset',
    'directional_sheet',
    'effect_sheet',
    'projectile',
    'pickup',
    'book',
]

for family in sprite_families:
    source = REFERENCE_DIR / f"{family}_source.json"
    output_png = REFERENCE_DIR / f"{family}_reference.png"
    temp_dir = REFERENCE_DIR / f"__temp_{family}"
    
    # Clean up any existing temp dir
    if temp_dir.exists():
        shutil.rmtree(temp_dir)
    temp_dir.mkdir()
    
    print(f"Compiling {family}...", end=" ", flush=True)
    try:
        program = load_compiler_program(str(source))
        result = compile_program(program, str(temp_dir), repo_root=Path("."), program_path=str(source))
        
        # Find the sheet.png in the temp dir
        sheet = temp_dir / "sheet.png"
        if sheet.exists():
            shutil.copy(sheet, output_png)
            print(f"OK -> {output_png}")
        else:
            print(f"ERROR: sheet.png not found")
        
        # Clean up temp dir
        shutil.rmtree(temp_dir)
    except Exception as e:
        print(f"ERROR: {e}")
        if temp_dir.exists():
            shutil.rmtree(temp_dir)
