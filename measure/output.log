import json
from pathlib import Path
from asf.compilers import load_compiler_program, compile_program
from asf.presentation_surfaces import (
    load_cover_surface, load_loading_surface, load_parallax_layer_set,
    load_ui_sheet, load_promo_capture_job, assemble_cover_surface,
    assemble_loading_surface, assemble_parallax_layer_set, assemble_ui_sheet
)

REFERENCE_DIR = Path("reference/demo_assets")

# Sprite compiler families (use load_compiler_program + compile_program)
SPRITE_FAMILIES = ['character_sheet', 'prop_sheet', 'fx_sheet', 'tileset', 
                   'directional_sheet', 'effect_sheet', 'projectile', 'pickup']

# For these families, the program JSON uses "family" field
SPRITE_PROGRAM_FAMILY_MAP = {
    'character_sheet': 'character_sheet',
    'prop_sheet': 'prop_or_fx_sheet',  # prop_sheet programs use prop_or_fx_sheet family
    'fx_sheet': 'prop_or_fx_sheet',    # fx_sheet programs also use prop_or_fx_sheet family
    'tileset': 'tileset',
    'directional_sheet': 'directional_sheet',
    'effect_sheet': 'effect_sheet',
    'projectile': 'projectile',
    'pickup': 'pickup',
}

def compile_sprite_family(family: str, output_path: Path) -> bool:
    source_path = REFERENCE_DIR / f"{family}_source.json"
    actual_family = SPRITE_PROGRAM_FAMILY_MAP.get(family, family)
    
    # For prop_sheet and fx_sheet, we need to use prop_or_fx_sheet family in the JSON
    if family in ['prop_sheet', 'fx_sheet']:
        # Read the source, modify family field, and compile
        with open(source_path) as f:
            data = json.load(f)
        data['family'] = 'prop_or_fx_sheet'
        import tempfile
        import os
        with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as tmp:
            json.dump(data, tmp)
            tmp_path = tmp.name
        program = load_compiler_program(tmp_path)
        os.unlink(tmp_path)
    else:
        program = load_compiler_program(str(source_path))
    
    output_dir = output_path.parent
    compile_program(program, str(output_dir), repo_root=Path('.'), program_path=str(source_path))
    return True

# Presentation surface families
PRESENTATION_LOADERS = {
    'background_scene': None,  # Not handled here
    'parallax_layer': ('parallax_layer_set', load_parallax_layer_set, assemble_parallax_layer_set),
    'ui_sheet': ('ui_sheet', load_ui_sheet, assemble_ui_sheet),
    'presentation_surface': ('cover_surface', load_cover_surface, assemble_cover_surface),
}

print("Compiling sprite families...")
for family in SPRITE_FAMILIES:
    source = REFERENCE_DIR / f"{family}_source.json"
    output = REFERENCE_DIR / f"{family}_reference.png"
    print(f"  {family}...", end=" ", flush=True)
    try:
        compile_sprite_family(family, output)
        print(f"OK -> {output}")
    except Exception as e:
        print(f"ERROR: {e}")

print("\nCompiling presentation surfaces...")
for family, loader_info in PRESENTATION_LOADERS.items():
    if loader_info is None:
        print(f"  {family}: Requires scene assembly (skipped for now)")
        continue
    surface_family, loader_fn, assembler_fn = loader_info
    source = REFERENCE_DIR / f"{family}_source.json"
    output = REFERENCE_DIR / f"{family}_reference.png"
    print(f"  {family}...", end=" ", flush=True)
    try:
        with open(source) as f:
            data = json.load(f)
        # Ensure surface_family is correct
        data['surface_family'] = surface_family
        import tempfile
        import os
        with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as tmp:
            json.dump(data, tmp)
            tmp_path = tmp.name
        
        program = loader_fn(tmp_path)
        os.unlink(tmp_path)
        
        result = assembler_fn(program, repo_root=Path('.'))
        if result and hasattr(result, 'image') and result.image:
            result.image.save(output)
            print(f"OK -> {output}")
        else:
            print(f"ERROR: No image produced")
    except Exception as e:
        print(f"ERROR: {e}")

print("\nbackground_scene requires scene assembler (skipped)")
