+def _load_pickup_sheet_program(
+    payload: dict[str, Any], path: Path
+) -> PickupSheetProgram:
+    _require_exact_keys(
+        payload,
+        {
+            "family",
+            "program_id",
+            "program_version",
+            "style_pack",
+            "primitive_ids",
+            "variant_controls",
+            "layout",
+            "render_spec",
+            "palette",
+            "pickup_type",
+            "has_glow",
+        },
+        "pickup program",
+        path,
+    )
+    (
+        family,
+        program_id,
+        program_version,
+        primitive_ids,
+        variant_controls,
+        style_pack,
+        layout_payload,
+    ) = _parse_common_program_fields(payload, path, context="pickup program")
+    layout = _parse_layout(
+        layout_payload,
+        path=path,
+        context="pickup program.layout",
+        expected_mode=PICKUP_LAYOUT_MODE,
+        require_frame_size=True,
+        require_directions=False,
+    )
+    render_spec = None
+    render_spec_payload = payload.get("render_spec")
+    if render_spec_payload is not None:
+        if not isinstance(render_spec_payload, dict):
+            raise CompilerValidationError(
+                f"{path}: pickup program.render_spec must be an object or null"
+            )
+        render_spec = load_spec_payload(render_spec_payload)
+    palette_payload = _require_mapping(
+        payload, "palette", path=path, context="pickup program"
+    )
+    _require_exact_keys(palette_payload, {"primary", "secondary", "accent"}, "palette", path)
+    palette = PaletteSpec(
+        primary=_require_string(palette_payload, "primary", path=path, context="palette"),
+        secondary=_require_string(
+            palette_payload, "secondary", path=path, context="palette"
+        ),
+        accent=_require_string(palette_payload, "accent", path=path, context="palette"),
+    )
+    pickup_type = _require_string(payload, "pickup_type", path=path, context="pickup program")
+    valid_pickup_types = ("herb", "mineral", "potion", "key", "coin", "gem")
+    if pickup_type not in valid_pickup_types:
+        raise CompilerValidationError(
+            f"{path}: pickup program.pickup_type must be one of {valid_pickup_types}"
+        )
+    has_glow = _require_bool(payload, "has_glow", path=path, context="pickup program")
+    return PickupSheetProgram(
+        family=family,
+        program_id=program_id,
+        program_version=program_version,
+        style_pack=style_pack,
+        primitive_ids=primitive_ids,
