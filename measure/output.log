+def run_from_plan(
+    self,
+    brief: str,
+    families: tuple[str, ...],
+    counts: dict[str, int],
+    programs: list[dict[str, Any]] | None = None,
+    style_pack: str | None = None,
+    theme_pack: dict[str, Any] | None = None,
+) -> BatchJob:
+    """Create and run a batch job directly from an in-memory plan.
+
+    This skips the JSON file staging step and feeds programs directly
+    into the orchestrator state machine.
+
+    Args:
+        brief: Natural-language request description.
+        families: Tuple of family names to generate.
+        counts: Dict mapping family name to count of assets per family.
+        programs: Optional list of pre-generated program dicts.
+                 If None, programs will be generated by the planner.
+        style_pack: Optional style pack name.
+        theme_pack: Optional theme pack configuration.
+
+    Returns:
+        Completed BatchJob with asset_states populated.
+    """
+    import uuid
+
+    job_id = f"job_{uuid.uuid4().hex[:8]}"
+    job_root = self.job_root / ".asf" / "batch" / job_id
+    job_root.mkdir(parents=True, exist_ok=True)
+
+    asset_states = tuple(
+        AssetExecutionState(family=family, program_index=idx)
+        for family in families
+        for idx in range(counts.get(family, 0))
+    )
+    job = BatchJob(
+        job_id=job_id,
+        state=JobState.PENDING,
+        brief={"request": brief},
+        families=families,
+        counts=counts,
+        theme_pack=theme_pack,
+        style_pack=style_pack,
+        output_root=job_root,
+        retry_policy=RetryPolicy(
+            max_planner_retries=self.max_planner_retries,
+            max_compile_retries=self.max_compile_retries,
+            max_candidate_loop_retries=self.max_candidate_loop_retries,
+        ),
+        asset_states=asset_states,
+        created_at=_utc_now(),
+        updated_at=_utc_now(),
+        planner_version=VersionInfo(name="planner", version=1),
+        candidate_loop_version=VersionInfo(
+            name="candidate_loop", version=CANDIDATE_LOOP_VERSION
+        ),
+        compiler_versions=(VersionInfo(name="compiler", version=COMPILER_VERSION),),
+    )
+
+    if programs:
+        for idx, asset_state in enumerate(job.asset_states):
+            family = asset_state.family
+            if idx < len(programs):
+                prog = programs[idx]
+                prog_path = asset_program_path(
+                    job_root, job_id, family, asset_state.program_index
+                )
+                prog_path.parent.mkdir(parents=True, exist_ok=True)
+                serialized = json.dumps(prog, indent=2, sort_keys=True) + "\n"
+                prog_path.write_text(serialized, encoding="utf-8")
+                job.asset_states = tuple(
+                    replace(asset_state, state=AssetState.PLANNED, program_path=prog_path)
+                    if i == idx else a
+                    for i, asset_state in enumerate(job.asset_states)
+                )
+
+    return self.run_to_completion(job)
+
 def _prepare_job(self, job: BatchJob) -> BatchJob:
     if job.state != JobState.PENDING:
         return job
     return replace(job, state=JobState.PLANNING, updated_at=_utc_now())

